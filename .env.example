# ============================================================
# Environment Variables — NEVER commit real values to Git
# Copy this file to .env and fill in the values.
# ============================================================

# --- Database ---
# SQLite (dev): leave empty, the app defaults to ./portfolio.db
# PostgreSQL (prod): uncomment and set your DB URL
# DATABASE_URL=postgresql://user:password@host:5432/portfolio

# --- CORS ---
# Comma-separated list of allowed frontend origins (no trailing slash)
# ALLOWED_ORIGINS=https://yourportfolio.com,https://www.yourportfolio.com

# --- Debug ---
# Set to "true" to expose /docs and /redoc. Leave unset in production.
# DEBUG=true
